@page "/clients/create"
@attribute [Authorize(Policy = PolicyNames.OrgMemberOrAbove)]
@inject IClientService ClientService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageHeader Title="Create Client" />

<FormCard>
    <MudForm @ref="_form" @bind-IsValid="_isValid">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_name"
                              Label="Full Name"
                              Required="true"
                              RequiredError="Full name is required"
                              For="@(() => _name)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_email"
                              Label="Email Address"
                              Required="true"
                              RequiredError="Email is required"
                              Validation="@(new Func<string, string?>(v =>
                                  string.IsNullOrWhiteSpace(v) || v.Contains('@') ? null : "Enter a valid email"))"
                              For="@(() => _email)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_company" Label="Company" For="@(() => _company)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_phone" Label="Phone" For="@(() => _phone)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_panNumber" Label="PAN Number" For="@(() => _panNumber)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_address" Label="Address" Lines="3"
                              For="@(() => _address)" />
            </MudItem>
        </MudGrid>

        <FormActions SaveLabel="Create Client"
                     CancelHref="/clients"
                     Disabled="@(!_isValid)"
                     OnSave="@(async () => await SaveAsync())" />
    </MudForm>
</FormCard>

@code {
    private MudForm _form = null!;
    private bool _isValid;

    private string _name = string.Empty;
    private string _email = string.Empty;
    private string _company = string.Empty;
    private string _phone = string.Empty;
    private string _address = string.Empty;
    private string? _panNumber;

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();

        if (!_isValid) return;

        var request = new CreateClientRequest(
            _name.Trim(),
            _email.Trim(),
            _company.Trim(),
            _phone.Trim(),
            _address.Trim(),
            _panNumber?.Trim());

        try
        {
            await ClientService.CreateAsync(request);
            Snackbar.Add("Client created successfully.", Severity.Success);
            Navigation.NavigateTo("/clients");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create client: {ex.Message}", Severity.Error);
        }
    }
}
