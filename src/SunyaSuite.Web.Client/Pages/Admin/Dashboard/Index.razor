@page "/admin/dashboard"
@attribute [Authorize(Policy = PolicyNames.SystemAdminOnly)]
@inject ISystemDashboardService DashboardService
@inject NavigationManager Navigation

<PageHeader Title="System Dashboard" />

<ErrorAlert Message="@_errorMessage" />

@if (_loading)
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <LoadingSkeleton Variant="SkeletonVariant.Card" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <LoadingSkeleton Variant="SkeletonVariant.Card" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <LoadingSkeleton Variant="SkeletonVariant.Card" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <LoadingSkeleton Variant="SkeletonVariant.Card" />
        </MudItem>
    </MudGrid>
    <MudPaper Elevation="0" Outlined="true" Class="pa-6 mt-6">
        <MudSkeleton Width="30%" Height="20px" Class="mb-4" />
        <MudSkeleton Width="100%" Height="200px" />
    </MudPaper>
}
else if (_stats is not null)
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Outlined="true" Class="pa-4 stat-card stat-card-default">
                <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Total Organizations</MudText>
                <MudText Typo="Typo.h3">@_stats.TotalOrganizations</MudText>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Outlined="true" Class="pa-4 stat-card stat-card-success">
                <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Active Organizations</MudText>
                <MudText Typo="Typo.h3">@_stats.ActiveOrganizations</MudText>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Outlined="true" Class="pa-4 stat-card stat-card-warning">
                <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Total Users</MudText>
                <MudText Typo="Typo.h3">@_stats.TotalUsers</MudText>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Outlined="true" Class="pa-4 stat-card stat-card-error">
                <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Org Memberships</MudText>
                <MudText Typo="Typo.h3">@_stats.TotalOrgMemberships</MudText>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-4">
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Outlined="true" Class="pa-4 stat-card stat-card-default">
                <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Deleted Orgs</MudText>
                <MudText Typo="Typo.h3" Color="@(_stats.DeletedOrganizations > 0 ? Color.Error : Color.Default)">
                    @_stats.DeletedOrganizations
                </MudText>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard Elevation="0" Outlined="true" Class="pa-4 stat-card stat-card-info">
                <MudText Typo="Typo.subtitle2" Class="text-secondary mb-1">Separate DB Orgs</MudText>
                <MudText Typo="Typo.h3">@_stats.SeparateDbOrgs</MudText>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Outlined="true" Class="pa-6 mt-6">
        <MudText Typo="Typo.subtitle2" Class="mb-4">Recent Organizations</MudText>
        @if (_stats.RecentOrganizations.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="text-disabled">No organizations yet.</MudText>
        }
        else
        {
            <MudTable T="RecentOrgDto" Items="@_stats.RecentOrganizations" Dense="true" Hover="true"
                      Outlined="false" Elevation="0">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Slug</MudTh>
                    <MudTh>Database</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Created</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudLink Href="@($"/admin/organizations/{context.Id}")" Typo="Typo.body2" Class="font-weight-bold">
                            @context.Name
                        </MudLink>
                    </MudTd>
                    <MudTd>@context.Slug</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.HasSeparateDb ? Color.Tertiary : Color.Default)">
                            @(context.HasSeparateDb ? "Separate" : "Shared")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.IsActive ? Color.Success : Color.Error)">
                            @(context.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.CreatedAt.ToString("MMM dd, yyyy")</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
}

@code {
    private bool _loading = true;
    private string? _errorMessage;
    private SystemDashboardStats? _stats;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _stats = await DashboardService.GetStatsAsync();
        }
        catch
        {
            _errorMessage = "Failed to load system dashboard data.";
        }
        finally
        {
            _loading = false;
        }
    }
}
