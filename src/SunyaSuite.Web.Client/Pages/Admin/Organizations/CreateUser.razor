@page "/admin/organizations/{Id:guid}/create-user"
@attribute [Authorize(Policy = PolicyNames.SystemAdminOnly)]
@inject IOrganizationService OrganizationService
@inject IUserService UserService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageHeader Title="@(_org is null ? "Create User" : $"Create User for {_org.Name}")" />

<ErrorAlert Message="@_errorMessage"
            OnDismiss="@(() => _errorMessage = null)" />

@if (_loading)
{
    <LoadingSkeleton Variant="SkeletonVariant.Form" />
}
else if (_org is null)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">Organization not found.</MudAlert>
}
else
{
    <FormCard MaxWidth="600px">
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.body2" Class="text-secondary mb-1">Organization</MudText>
                    <MudText Typo="Typo.body1" Class="mb-4">@_org.Name (@_org.Slug)</MudText>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_firstName" Label="First Name" Required="true" RequiredError="First name is required" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_lastName" Label="Last Name" Required="true" RequiredError="Last name is required" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_email" Label="Email" Required="true" RequiredError="Email is required"
                                  Validation="@(new Func<string, string?>(v => string.IsNullOrWhiteSpace(v) || v.Contains('@') ? null : "Enter a valid email"))" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_password" Label="Password" InputType="InputType.Password"
                                  Required="true" RequiredError="Password is required" />
                </MudItem>
                <MudItem xs="12" Class="mt-4">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">System Roles</MudText>
                    @if (_allRoles.Count == 0)
                    {
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var role in _allRoles)
                            {
                                var r = role;
                                var selected = _selectedRoles.Contains(r);
                                <MudButton @key="role" Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                                           Color="@(selected ? Color.Primary : Color.Default)"
                                           OnClick="@(() => ToggleRole(r))">
                                    @r
                                </MudButton>
                            }
                        </div>
                    }
                </MudItem>
                <MudItem xs="12" Class="mt-4">
                    <MudSelect @bind-Value="_orgRole"
                               Label="Organization Role"
                               Required="true"
                               RequiredError="Organization role is required"
                               For="@(() => _orgRole)">
                        @foreach (var role in _orgRoles)
                        {
                            <MudSelectItem Value="@role" @key="role">@role</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <FormActions SaveLabel="Create User"
                         SavingText="Creating..."
                         CancelHref="@($"/admin/organizations/{Id}")"
                         Disabled="@(!_isValid)"
                         Saving="@_saving"
                         OnSave="@(async () => await Save())" />
        </MudForm>
    </FormCard>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private bool _saving;
    private bool _isValid;
    private MudForm _form = null!;
    private string? _errorMessage;
    private OrganizationDto? _org;
    private List<string> _allRoles = [];
    private List<string> _orgRoles = [];
    private HashSet<string> _selectedRoles = [];

    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _orgRole = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _org = await OrganizationService.GetByIdAsync(Id);
            if (_org is null)
                return;

            _allRoles = await UserService.GetAllRolesAsync();
            _orgRoles = [..OrgRoles.All];
        }
        catch
        {
            _errorMessage = "Failed to load data.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleRole(string role)
    {
        if (!_selectedRoles.Remove(role))
            _selectedRoles.Add(role);
    }

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _saving = true;
        _errorMessage = null;

        try
        {
            var request = new CreateOrgUserRequest
            {
                Email = _email,
                Password = _password,
                FirstName = _firstName,
                LastName = _lastName,
                Roles = _allRoles.Where(r => _selectedRoles.Contains(r)).ToList(),
                OrgRole = _orgRole
            };

            await OrganizationService.CreateUserForOrganizationAsync(Id, request);
            Snackbar.Add("User created and assigned to organization.", Severity.Success);
            Navigation.NavigateTo($"/admin/organizations/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create user: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
