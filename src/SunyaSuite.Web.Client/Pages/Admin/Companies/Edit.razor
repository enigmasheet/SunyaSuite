@page "/admin/companies/edit/{Id:guid}"
@attribute [Authorize(Policy = PolicyNames.OrgAdminOrAbove)]
@inject ICompanyService CompanyService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageHeader Title="@(_companyName is null ? "Edit Company" : $"Edit: {_companyName}")" />

<ErrorAlert Message="@_errorMessage"
            OnDismiss="@(() => _errorMessage = null)" />

@if (_loading)
{
    <LoadingSkeleton Variant="SkeletonVariant.Form" />
}
else if (_notFound)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">Company not found.</MudAlert>
}
else
{
    <FormCard>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_name"
                                  Label="Company Name"
                                  Required="true"
                                  RequiredError="Company name is required"
                                  For="@(() => _name)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_slug"
                                  Label="Slug"
                                  Required="true"
                                  RequiredError="Slug is required"
                                  HelperText="Lowercase letters, numbers, and hyphens"
                                  For="@(() => _slug)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_email"
                                  Label="Email Address"
                                  For="@(() => _email)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_phone" Label="Phone" For="@(() => _phone)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_panNumber" Label="PAN Number" For="@(() => _panNumber)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSwitch @bind-Value="_isActive" Color="Color.Primary">Active</MudSwitch>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_address" Label="Address" Lines="3"
                                  For="@(() => _address)" />
                </MudItem>
            </MudGrid>

            <MudGrid Class="mt-4">
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-2">Company Logo</MudText>
                    <div class="d-flex align-start gap-4">
                        <div>
                            @if (!string.IsNullOrEmpty(_logoPreview))
                            {
                                <img src="@_logoPreview" alt="Logo preview" style="max-width: 200px; max-height: 200px; border: 1px solid #ddd; border-radius: 4px;" />
                            }
                            else if (!string.IsNullOrEmpty(_existingLogo))
                            {
                                <img src="@_existingLogo" alt="Current logo" style="max-width: 200px; max-height: 200px; border: 1px solid #ddd; border-radius: 4px;" />
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="text-secondary">No logo uploaded</MudText>
                            }
                        </div>
                        <div class="d-flex flex-column gap-2">
                            <InputFile OnChange="@OnLogoSelected"
                                       accept=".png,.jpg,.jpeg,.gif,.webp" />
                            <MudText Typo="Typo.caption" Class="text-secondary">PNG, JPG, GIF, or WebP (max 2 MB)</MudText>
                            @if (!string.IsNullOrEmpty(_logoPreview) || !string.IsNullOrEmpty(_existingLogo))
                            {
                                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                                           OnClick="@ClearLogo">Remove Logo</MudButton>
                            }
                        </div>
                    </div>
                </MudItem>
            </MudGrid>

            <FormActions SaveLabel="Save Changes"
                         CancelHref="/admin/companies"
                         Disabled="@(!_isValid)"
                         OnSave="@(async () => await SaveAsync())" />
        </MudForm>
    </FormCard>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading = true;
    private bool _notFound;
    private string? _errorMessage;
    private string? _companyName;

    private string _name = string.Empty;
    private string _slug = string.Empty;
    private string _email = string.Empty;
    private string _phone = string.Empty;
    private string _address = string.Empty;
    private string? _panNumber;
    private bool _isActive = true;
    private string? _existingLogo;
    private string? _logoPreview;
    private string? _logoBase64;
    private bool _logoCleared;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var company = await CompanyService.GetByIdAsync(Id);
            if (company is null)
            {
                _notFound = true;
            }
            else
            {
                _companyName = company.Name;
                _name = company.Name;
                _slug = company.Slug;
                _email = company.Email;
                _phone = company.Phone;
                _address = company.Address;
                _panNumber = company.PanNumber;
                _isActive = company.IsActive;
                _existingLogo = company.LogoBase64;
            }
        }
        catch
        {
            _errorMessage = "Failed to load data.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        var file = e.GetMultipleFiles(1).FirstOrDefault();
        if (file is null) return;

        const int maxSize = 2 * 1024 * 1024;
        if (file.Size > maxSize)
        {
            Snackbar.Add("Logo must be under 2 MB.", Severity.Error);
            return;
        }

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxSize).CopyToAsync(ms);
        _logoBase64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
        _logoPreview = _logoBase64;
    }

    private void ClearLogo()
    {
        _logoBase64 = null;
        _logoPreview = null;
        _logoCleared = true;
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        var logo = _logoCleared ? null : _logoBase64 ?? _existingLogo;

        var request = new UpdateCompanyRequest(
            Id,
            _name.Trim(),
            _slug.Trim().ToLowerInvariant(),
            _email.Trim(),
            _address.Trim(),
            _phone.Trim(),
            _panNumber?.Trim(),
            _isActive,
            logo);

        try
        {
            await CompanyService.UpdateAsync(request);
            Snackbar.Add("Company updated successfully.", Severity.Success);
            Navigation.NavigateTo("/admin/companies");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update company: {ex.Message}", Severity.Error);
        }
    }
}
