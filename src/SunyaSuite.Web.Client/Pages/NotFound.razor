@page "/404"
@layout AuthLayout

<PageTitle>Page Not Found — SunyaSuite</PageTitle>

<MudCard Class="auth-card" Elevation="0">
    <MudCardContent>
        <MudText Typo="Typo.h3" Align="Align.Center" Class="mb-4">404</MudText>
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-4">The page you are looking for does not exist.</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="/">
            Go Home
        </MudButton>
    </MudCardContent>
</MudCard>
