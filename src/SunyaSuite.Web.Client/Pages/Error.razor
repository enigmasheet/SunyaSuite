@page "/Error"

<PageTitle>Error — SunyaSuite</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center py-16">
    <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="@Size.Large" Color="@Color.Error" Class="mb-4" />
    <MudText Typo="Typo.h3" Align="@Align.Center" Class="mb-2">Something went wrong</MudText>
    <MudText Typo="Typo.body1" Align="@Align.Center" Class="mb-4">An error occurred while processing your request.</MudText>

    <MudButton Variant="@Variant.Filled" Color="@Color.Primary" Href="/">Go Home</MudButton>
</MudContainer>
