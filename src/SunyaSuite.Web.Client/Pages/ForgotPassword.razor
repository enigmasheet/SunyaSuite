@page "/Account/ForgotPassword"
@layout AuthLayout
@using System.Text.Json
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Forgot Password — SunyaSuite</PageTitle>

<MudCard Class="auth-card" Elevation="0">
    <MudCardContent>
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-8">Reset Password</MudText>

        <ErrorAlert Message="@_errorMessage" />
        @if (_success)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                If the email exists, a reset link has been sent.
            </MudAlert>
        }

        <MudForm @ref="_form" @bind-IsValid="@_isValid" @bind-Errors="@_errors">
            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined" Class="mb-4" Required="true"
                          For="@(() => _email)" Validation="@((string? v) => v?.Contains('@') == true ? null : "Enter a valid email address")" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="@HandleForgotPassword" Disabled="@(_loading || !_isValid)" Class="mb-4">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Class="ms-2" />
                }
                Send Reset Link
            </MudButton>
        </MudForm>

        <MudText Typo="Typo.body2" Align="Align.Center">
            <MudLink Href="/login">Back to sign in</MudLink>
        </MudText>
    </MudCardContent>
</MudCard>

@code {
    private MudForm? _form;
    private string _email = "";
    private bool _loading;
    private bool _isValid = true;
    private string[] _errors = [];
    private string _errorMessage = "";
    private bool _success;

    private async Task HandleForgotPassword()
    {
        _loading = true;
        _errorMessage = "";
        _success = false;

        try
        {
            var http = HttpClientFactory.CreateClient("Api");
            var response = await http.PostAsJsonAsync("api/auth/forgot-password", new { email = _email });

            if (response.IsSuccessStatusCode)
            {
                _success = true;
            }
            else
            {
                _errorMessage = "An error occurred. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Connection error: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }
}
