@page "/Account/Manage/ChangePassword"
@attribute [Authorize]
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IHttpClientFactory HttpClientFactory

<PageHeader Title="Change Password" />

<MudPaper Elevation="0" Outlined="true" Class="pa-6" Style="max-width: 600px;">
    <MudForm @ref="_form" Model="@_model">
        <MudTextField @bind-Value="_model.CurrentPassword"
                      Label="Current Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Required="true"
                      For="@(() => _model.CurrentPassword)" />
        <MudTextField @bind-Value="_model.NewPassword"
                      Label="New Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Required="true"
                      For="@(() => _model.NewPassword)" />
        <MudTextField @bind-Value="_model.ConfirmNewPassword"
                      Label="Confirm New Password"
                      InputType="InputType.Password"
                      Variant="Variant.Outlined"
                      Required="true"
                      For="@(() => _model.ConfirmNewPassword)" />
    </MudForm>

    <div Class="d-flex mt-6 gap-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@_saving"
                   OnClick="@(async () => await SubmitAsync())">
            @(_saving ? "Saving..." : "Save Password")
        </MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" Href="/Account/Manage">Cancel</MudButton>
    </div>
</MudPaper>

@code {
    private bool _saving;
    private MudForm? _form;
    private ChangePasswordModel _model = new();

    private async Task SubmitAsync()
    {
        await _form!.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            var response = await client.PostAsJsonAsync("api/auth/change-password", _model);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Password changed successfully.", Severity.Success);
                Navigation.NavigateTo("/Account/Manage");
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
                Snackbar.Add(error?.GetValueOrDefault("message") ?? "Failed to change password.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred while changing the password.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private class ChangePasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string CurrentPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 6)]
        public string NewPassword { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match")]
        public string ConfirmNewPassword { get; set; } = "";
    }
}
