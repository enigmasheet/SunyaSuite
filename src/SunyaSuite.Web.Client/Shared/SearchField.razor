<MudTextField Value="@Value"
              ValueChanged="@((string? v) => HandleValueChanged(v))"
              Placeholder="@Placeholder"
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Search"
              Clearable="true"
              DebounceInterval="@DebounceMs"
              Variant="Variant.Outlined"
              aria-label="Search"
              OnClearButtonClick="@(() => HandleClear())" />

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Search...";
    [Parameter] public EventCallback<string?> OnSearch { get; set; }
    [Parameter] public int DebounceMs { get; set; } = 300;

    private async Task HandleValueChanged(string? v)
    {
        await ValueChanged.InvokeAsync(v);
        await OnSearch.InvokeAsync(v);
    }

    private async Task HandleClear()
    {
        await ValueChanged.InvokeAsync(null);
        await OnSearch.InvokeAsync(null);
    }
}
